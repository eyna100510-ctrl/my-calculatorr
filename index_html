<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Simple Integration Calculator & Grapher</title>
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/mathjs/11.8.0/math.js"></script>
    <style>
        body {
            font-family: system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, Cantarell, sans-serif;
        }
    </style>
</head>
<body class="bg-gray-50 text-gray-800 min-h-screen flex flex-col">

    <header class="bg-slate-900 text-white p-4 shadow-md">
        <div class="max-w-6xl mx-auto flex justify-between items-center">
            <h1 class="text-xl font-bold tracking-tight flex items-center gap-2">
                <span>∫</span> Integration Graphing Calculator
            </h1>
            <span class="text-sm text-slate-400 hidden sm:inline">A simpler alternative to Desmos for definite integrals</span>
        </div>
    </header>

    <main class="flex-1 max-w-6xl w-full mx-auto p-4 grid grid-cols-1 md:grid-cols-3 gap-6">
        
        <div class="md:col-span-1 bg-white p-6 rounded-xl shadow-sm border border-gray-200 flex flex-col gap-5 h-fit">
            <h2 class="text-lg font-semibold text-gray-700 border-b pb-2">Function & Bounds</h2>
            
            <div class="flex flex-col gap-1">
                <label for="function-input" class="text-sm font-medium text-gray-600">Function f(x)</label>
                <div class="relative">
                    <span class="absolute left-3 top-2.5 text-gray-400 italic">f(x) =</span>
                    <input type="text" id="function-input" value="x^2 - 2x" 
                        class="w-full pl-14 pr-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500 font-mono text-lg">
                </div>
                <p class="text-xs text-gray-400 mt-1">Supports: x^2, sin(x), cos(x), log(x), exp(x), sqrt(x)</p>
            </div>

            <div class="grid grid-cols-2 gap-4">
                <div class="flex flex-col gap-1">
                    <label for="bound-a" class="text-sm font-medium text-gray-600">Lower Bound (a)</label>
                    <input type="number" id="bound-a" value="0" step="any"
                        class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500 font-mono">
                </div>
                <div class="flex flex-col gap-1">
                    <label for="bound-b" class="text-sm font-medium text-gray-600">Upper Bound (b)</label>
                    <input type="number" id="bound-b" value="3" step="any"
                        class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500 font-mono">
                </div>
            </div>

            <div id="error-box" class="hidden bg-red-50 text-red-600 p-3 rounded-md text-sm border border-red-200 font-medium">
            </div>

            <div class="bg-slate-50 p-4 rounded-xl border border-slate-200 mt-2">
                <h3 class="text-xs font-bold uppercase tracking-wider text-slate-400 mb-1">Definite Integral Result</h3>
                <div class="flex flex-col gap-1">
                    <div class="text-sm font-mono text-slate-600">
                        <span class="text-lg">∫</span><sub id="display-a" class="text-xs">0</sub><sup id="display-b" class="text-xs">3</sup> <span id="display-fx" class="italic font-serif font-bold">f(x)</span> dx
                    </div>
                    <div id="result-value" class="text-3xl font-bold text-blue-600 font-mono mt-1">
                        Calculating...
                    </div>
                </div>
            </div>
        </div>

        <div class="md:col-span-2 bg-white p-4 rounded-xl shadow-sm border border-gray-200 flex flex-col min-h-[450px]">
            <div class="flex justify-between items-center mb-2">
                <h2 class="text-lg font-semibold text-gray-700">Visualized Area</h2>
                <span class="text-xs bg-blue-50 text-blue-700 px-2 py-1 rounded border border-blue-200 font-medium">Shaded area represents the integral</span>
            </div>
            <div class="flex-1 relative w-full h-full">
                <canvas id="graphCanvas"></canvas>
            </div>
        </div>

    </main>

    <footer class="bg-white border-t border-gray-200 py-4 text-center text-xs text-gray-500 mt-auto">
        Calculated using numerical integration (Simpson's Rule). Powered by Math.js and Chart.js.
    </footer>

    <script>
        // DOM Elements
        const functionInput = document.getElementById('function-input');
        const boundAInput = document.getElementById('bound-a');
        const boundBInput = document.getElementById('bound-b');
        const errorBox = document.getElementById('error-box');
        const resultValue = document.getElementById('result-value');
        const displayA = document.getElementById('display-a');
        const displayB = document.getElementById('display-b');
        const displayFx = document.getElementById('display-fx');
        const ctx = document.getElementById('graphCanvas').getContext('2d');

        let myChart = null;

        // Numerical Integration using Simpson's Rule
        function calculateIntegral(f, a, b, n = 1000) {
            if (n % 2 !== 0) n++; // Simpson's rule requires an even number of intervals
            const h = (b - a) / n;
            let sum = f(a) + f(b);

            for (let i = 1; i < n; i++) {
                const x = a + i * h;
                sum += i % 2 === 0 ? 2 * f(x) : 4 * f(x);
            }

            return (h / 3) * sum;
        }

        // Main Calculation and Plotting Pipeline
        function updateCalculator() {
            // Clear prior errors
            errorBox.classList.add('hidden');
            errorBox.innerText = '';

            const formulaStr = functionInput.value.trim();
            const a = parseFloat(boundAInput.value);
            const b = parseFloat(boundBInput.value);

            // Validation
            if (!formulaStr) {
                showError("Please enter a valid function.");
                return;
            }
            if (isNaN(a) || !isFinite(a) || isNaN(b) || !isFinite(b)) {
                showError("Please provide valid, finite numeric bounds.");
                return;
            }

            try {
                // Compile the math string to a safe JS function using math.js
                const compiledExpr = math.compile(formulaStr);
                const f = (x) => compiledExpr.evaluate({ x: x });

                // Test run evaluation to check for structural/variable expression errors
                const testEval = f(a);
                if (typeof testEval !== 'number' || isNaN(testEval)) {
                    throw new Error("Function returned an invalid result. Ensure 'x' is your only variable.");
                }

                // Calculate definite integral
                const integralVal = calculateIntegral(f, a, b);
                
                // Update text displays
                displayA.innerText = a;
                displayB.innerText = b;
                displayFx.innerText = formulaStr;
                resultValue.innerText = Number(integralVal.toFixed(5)).toLocaleString();

                // Prepare Graph Data arrays
                const labels = [];
                const mainLineData = [];
                const integratedAreaData = [];

                // Establish a dynamic graphing viewport slightly wider than the defined bounds
                const padding = Math.max(Math.abs(b - a) * 0.4, 2);
                const minX = Math.min(a, b) - padding;
                const maxX = Math.max(a, b) + padding;
                const steps = 200; 
                const stepSize = (maxX - minX) / steps;

                for (let i = 0; i <= steps; i++) {
                    const x = minX + (i * stepSize);
                    let y = null;
                    
                    try {
                        y = f(x);
                    } catch(e) {}

                    // Only push valid numerical data points
                    if (typeof y === 'number' && isFinite(y)) {
                        labels.push(x);
                        mainLineData.push({ x: x, y: y });

                        // Check if current x lies inside the integration bounds [a, b]
                        const lowerBound = Math.min(a, b);
                        const upperBound = Math.max(a, b);
                        if (x >= lowerBound && x <= upperBound) {
                            integratedAreaData.push({ x: x, y: y });
                        }
                    }
                }

                // Render or Refresh Chart.js Instance
                renderChart(labels, mainLineData, integratedAreaData, a, b);

            } catch (err) {
                showError("Parsing Error: " + err.message);
                resultValue.innerText = "Error";
            }
        }

        function showError(msg) {
            errorBox.innerText = msg;
            errorBox.classList.remove('hidden');
        }

        function renderChart(labels, mainLineData, integratedAreaData, a, b) {
            if (myChart) {
                myChart.destroy();
            }

            myChart = new Chart(ctx, {
                type: 'line',
                data: {
                    datasets: [
                        {
                            label: 'f(x)',
                            data: mainLineData,
                            borderColor: 'rgb(59, 130, 246)', // Blue line
                            borderWidth: 3,
                            pointRadius: 0,
                            fill: false,
                            tension: 0.1,
                            order: 1
                        },
                        {
                            label: '∫ f(x) dx',
                            data: integratedAreaData,
                            borderColor: 'transparent',
                            backgroundColor: 'rgba(59, 130, 246, 0.25)', // Transparent blue fill
                            pointRadius: 0,
                            fill: 'origin', // Fills down to y=0 axis
                            order: 2
                        }
                    ]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    scales: {
                        x: {
                            type: 'linear',
                            position: 'bottom',
                            grid: {
                                color: 'rgba(0, 0, 0, 0.06)'
                            },
                            title: {
                                display: true,
                                text: 'x'
                            }
                        },
                        y: {
                            type: 'linear',
                            grid: {
                                color: 'rgba(0, 0, 0, 0.06)'
                            },
                            title: {
                                display: true,
                                text: 'y'
                            }
                        }
                    },
                    plugins: {
                        legend: {
                            display: false // Hide messy default legend UI
                        },
                        tooltip: {
                            callbacks: {
                                label: function(context) {
                                    return `(${context.parsed.x.toFixed(2)}, ${context.parsed.y.toFixed(2)})`;
                                }
                            }
                        }
                    }
                }
            });
        }

        // Attach Instant Reactive Event Listeners
        [functionInput, boundAInput, boundBInput].forEach(element => {
            element.addEventListener('input', updateCalculator);
        });

        // Initialize App on Page Load
        updateCalculator();
    </script>
</body>
</html>
